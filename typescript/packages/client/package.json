{
  "name": "@splendor/client",
  "version": "0.1.0",
  "description": "Thin TypeScript daemon client for Splendor local runtime control.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --pretty false",
    "clean": "tsc -b --clean"
  },
  "dependencies": {
    "@splendor/types": "0.1.0"
  }
}
