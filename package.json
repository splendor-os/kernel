{
  "name": "splendor-kernel-workspace",
  "private": true,
  "version": "0.1.0",
  "description": "Splendor Kernel development workspace",
  "type": "module",
  "workspaces": [
    "typescript/packages/*"
  ],
  "scripts": {
    "build": "tsc -b typescript/packages/types typescript/packages/client",
    "typecheck": "tsc -b --pretty false typescript/packages/types typescript/packages/client typescript/tests",
    "test": "npm run build && npm run typecheck && node --test typescript/tests/dist/*.test.js",
    "coverage": "npm run build && npm run typecheck && node --test --experimental-test-coverage --test-coverage-lines=95 typescript/tests/dist/*.test.js",
    "clean": "tsc -b --clean typescript/packages/types typescript/packages/client typescript/tests"
  },
  "devDependencies": {
    "@types/node": "20.14.12",
    "typescript": "5.5.4"
  }
}
